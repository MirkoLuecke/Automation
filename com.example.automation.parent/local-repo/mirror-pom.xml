<?xml version="1.0" encoding="UTF-8"?>
<project>
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.example.automation</groupId>
  <artifactId>local-repo-mirror</artifactId>
  <version>1.0.0</version>
  <packaging>pom</packaging>

  <!--
    Run this once on a machine with internet access to populate local-repo/p2/.
    Command: mvn package -f local-repo/mirror-pom.xml
    (run from the com.example.automation.parent directory)

    Produces:
      local-repo/p2/pde/     - Eclipse PDE (required for opening plugin projects)
      local-repo/p2/swtbot/  - SWTBot (required for running the test suite)

    A PowerShell post-step injects p2 category IUs into each repo so that
    "Install New Software" groups items by name. Script is idempotent.
  -->

  <build>
    <plugins>
      <plugin>
        <groupId>org.eclipse.tycho.extras</groupId>
        <artifactId>tycho-p2-extras-plugin</artifactId>
        <version>3.0.5</version>
        <executions>

          <execution>
            <id>mirror-pde</id>
            <phase>package</phase>
            <goals><goal>mirror</goal></goals>
            <configuration>
              <source>
                <repository>
                  <url>https://download.eclipse.org/releases/2023-06/</url>
                  <layout>p2</layout>
                </repository>
              </source>
              <ius>
                <iu>
                  <id>org.eclipse.pde.feature.group</id>
                  <version>0.0.0</version>
                </iu>
              </ius>
              <destination>${project.basedir}/p2/pde</destination>
              <followStrictOnly>true</followStrictOnly>
              <includeOptional>false</includeOptional>
              <includeNonGreedy>false</includeNonGreedy>
              <includeAllPlatforms>false</includeAllPlatforms>
              <latestVersionOnly>true</latestVersionOnly>
            </configuration>
          </execution>

          <execution>
            <id>mirror-swtbot</id>
            <phase>package</phase>
            <goals><goal>mirror</goal></goals>
            <configuration>
              <source>
                <repository>
                  <url>https://download.eclipse.org/technology/swtbot/releases/latest/</url>
                  <layout>p2</layout>
                </repository>
              </source>
              <ius>
                <iu>
                  <id>org.eclipse.swtbot.eclipse.feature.group</id>
                  <version>0.0.0</version>
                </iu>
              </ius>
              <destination>${project.basedir}/p2/swtbot</destination>
              <followStrictOnly>true</followStrictOnly>
              <includeOptional>false</includeOptional>
              <includeNonGreedy>false</includeNonGreedy>
              <includeAllPlatforms>false</includeAllPlatforms>
              <latestVersionOnly>true</latestVersionOnly>
            </configuration>
          </execution>

        </executions>
      </plugin>

      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.1.0</version>
        <executions>

          <execution>
            <id>inject-pde-category</id>
            <phase>package</phase>
            <goals><goal>exec</goal></goals>
            <configuration>
              <executable>powershell</executable>
              <arguments>
                <argument>-NonInteractive</argument>
                <argument>-ExecutionPolicy</argument><argument>Bypass</argument>
                <argument>-File</argument>
                <argument>${project.basedir}/patch-p2-category.ps1</argument>
                <argument>-RepoDir</argument>
                <argument>${project.basedir}/p2/pde</argument>
                <argument>-CategoryId</argument>
                <argument>com.example.automation.pde.category</argument>
                <argument>-CategoryLabel</argument>
                <argument>Eclipse Plug-in Development Environment</argument>
                <argument>-FeatureGroupId</argument>
                <argument>org.eclipse.pde.feature.group</argument>
              </arguments>
            </configuration>
          </execution>

          <execution>
            <id>inject-swtbot-category</id>
            <phase>package</phase>
            <goals><goal>exec</goal></goals>
            <configuration>
              <executable>powershell</executable>
              <arguments>
                <argument>-NonInteractive</argument>
                <argument>-ExecutionPolicy</argument><argument>Bypass</argument>
                <argument>-File</argument>
                <argument>${project.basedir}/patch-p2-category.ps1</argument>
                <argument>-RepoDir</argument>
                <argument>${project.basedir}/p2/swtbot</argument>
                <argument>-CategoryId</argument>
                <argument>com.example.automation.swtbot.category</argument>
                <argument>-CategoryLabel</argument>
                <argument>SWTBot for Eclipse</argument>
                <argument>-FeatureGroupId</argument>
                <argument>org.eclipse.swtbot.eclipse.feature.group</argument>
              </arguments>
            </configuration>
          </execution>

        </executions>
      </plugin>
    </plugins>
  </build>
</project>
