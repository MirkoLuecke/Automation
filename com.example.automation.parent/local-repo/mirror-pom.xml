<?xml version="1.0" encoding="UTF-8"?>
<project>
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.example.automation</groupId>
  <artifactId>local-repo-mirror</artifactId>
  <version>1.0.0</version>
  <packaging>pom</packaging>

  <!--
    Run this once on a machine with internet access to populate local-repo/p2/pde/.
    Command: mvn package -f local-repo/mirror-pom.xml
    (run from the com.example.automation.parent directory)
  -->

  <build>
    <plugins>
      <plugin>
        <groupId>org.eclipse.tycho.extras</groupId>
        <artifactId>tycho-p2-extras-plugin</artifactId>
        <version>3.0.5</version>
        <executions>
          <execution>
            <id>mirror-pde</id>
            <phase>package</phase>
            <goals>
              <goal>mirror</goal>
            </goals>
            <configuration>
              <source>
                <repository>
                  <url>https://download.eclipse.org/releases/2023-06/</url>
                  <layout>p2</layout>
                </repository>
              </source>
              <ius>
                <iu>
                  <id>org.eclipse.pde.feature.group</id>
                  <version>0.0.0</version>
                </iu>
              </ius>
              <destination>${project.basedir}/p2/pde</destination>
              <includeOptional>false</includeOptional>
              <includeAllPlatforms>false</includeAllPlatforms>
              <latestVersionOnly>true</latestVersionOnly>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
